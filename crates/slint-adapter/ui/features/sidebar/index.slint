import { Environments } from "../environments/views/environments.slint";
import { ScrollView } from "std-widgets.slint";
import { Navigation } from "navigation.slint";
import { Tabs } from "../tabs/globals.slint";
import { Sidebar } from "../sidebar/globals.slint";
import { WindowClickHandler } from "title/title-bar.slint";
import { NavItem } from "components/nav-item.slint";
import { PageData } from "content/globals.slint";
import { Theme } from "theme.slint";
import { ResizeHandle } from "resize-handle.slint";
import { WindowAdapter, WindowSize } from "window-adapter.slint";

export component SideBar inherits Rectangle {

    private property <[PageData]> current-pages: Tabs.tabs[Tabs.active_tab_index].pages;

    private property <length> prop-min-width: 200px;
    private property <length> prop-max-width: 500px;
    private property <length> collapse-threshold: 80px;
    private property <length> collapsed-width: 58px;
    private property <bool> is-collapsed: WindowAdapter.size == WindowSize.sm || Sidebar.side_bar_width <= root.collapsed-width;

    width: WindowAdapter.size == WindowSize.sm ? root.collapsed-width : Sidebar.side_bar_width;

    states [
        collapsed when root.is-collapsed: {
            width: root.collapsed-width;
            in {
                animate width {
                    duration: Theme.durationFast;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1.0);
                }
            }
        }
        expanded when !root.is-collapsed: {
            width: Sidebar.side_bar_width;
            in {
                animate width {
                    duration: Theme.durationFast;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1.0);
                }
            }
        }
    ]

    accessible-role: AccessibleRole.button;

    private property <length> nav-item-height: 40px;
    private property <length> nav-item-spacing: 4px;

    private property <int> active-sidebar-index: root.current-pages.length > 0 ? min(max(Tabs.active_page_index, 0), root.current-pages.length - 1) : 0;

    private property <float> indicator-progress: Sidebar.switch_progress;
    private property <float> indicator-eased-progress: root.indicator-progress * root.indicator-progress * (3.0 - 2.0 * root.indicator-progress) - 0.38;
    private property <bool> indicator-transition-active: Sidebar.switch_from_index >= 0 && Sidebar.switch_to_index >= 0 && Sidebar.switch_from_index != Sidebar.switch_to_index && root.indicator-progress > 0.001 && root.indicator-progress < 0.999;
    private property <float> indicator-direction: Sidebar.switch_to_index >= Sidebar.switch_from_index ? 1.0 : -1.0;
    private property <length> indicator-center-y: (root.nav-item-height - Theme.selection_indicator_height) / 2;
    private property <length> indicator-max-height: Theme.selection_indicator_height + 12px;
    private property <float> from-phase: min(root.indicator-eased-progress / 0.5, 1.0);
    private property <float> to-phase: min(max(root.indicator-eased-progress / 0.5, 0.0), 1.0);

    private property <length> from-indicator-height: Theme.selection_indicator_height * (1.0 - root.from-phase);
    private property <length> to-indicator-height: root.indicator-eased-progress < 0.3 ? 0px : (root.indicator-eased-progress < 0.6 ? (root.indicator-max-height * root.to-phase) : (root.indicator-max-height - (root.indicator-max-height - Theme.selection_indicator_height) * root.to-phase));
    private property <length> from-indicator-y: root.indicator-direction > 0.0 ? (root.nav-item-height - root.from-indicator-height) : 0px;
    private property <length> to-max-anchor-y: root.indicator-direction > 0.0 ? 0px : (root.nav-item-height - root.indicator-max-height);
    private property <length> to-grow-y: root.indicator-direction > 0.0 ? 0px : (root.nav-item-height - root.to-indicator-height);
    private property <length> to-indicator-y: root.indicator-eased-progress < 0.6 ? root.to-grow-y : (root.to-max-anchor-y + (root.indicator-center-y - root.to-max-anchor-y) * root.to-phase);

    unfocus := TouchArea {
        pointer-event(evt) => {
            if (evt.kind == PointerEventKind.down) {
                WindowClickHandler.window-clicked();
            }
        }
    }

    VerticalLayout {
        padding-top: 10px;
        padding: 6px;
        spacing: 4px;

        ScrollView {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            Rectangle {
                VerticalLayout {
                    spacing: 4px;
                    alignment: start;

                    nav-pages := VerticalLayout {
                        spacing: root.nav-item-spacing;

                        for page[idx] in root.current-pages: NavItem {
                            icon: page.icon;
                            text: page.text;
                            active: Tabs.active_page_index == idx;
                            colorize: false;
                            text-visible: !root.is-collapsed;
                            indicator-visible: root.indicator-transition-active ? ((idx == Sidebar.switch_from_index && root.from-indicator-height > 10px) || (idx == Sidebar.switch_to_index && root.to-indicator-height > 10px)) : (idx == root.active-sidebar-index);
                            indicator-height: root.indicator-transition-active ? (idx == Sidebar.switch_from_index ? root.from-indicator-height : (idx == Sidebar.switch_to_index ? root.to-indicator-height : Theme.selection_indicator_height)) : Theme.selection_indicator_height;
                            indicator-offset-y: root.indicator-transition-active ? (idx == Sidebar.switch_from_index ? root.from-indicator-y : (idx == Sidebar.switch_to_index ? root.to-indicator-y : root.indicator-center-y)) : root.indicator-center-y;
                            clicked => {
                                Navigation.push(page.path);
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.layer_background;
        }

        NavItem {
            icon-key: "settings";
            text: "Settings";
            active: false;
            colorize: false;
            text-visible: !root.is-collapsed;
            clicked => {
                Navigation.push("/settings");
            }
        }
    }

    ResizeHandle {
        x: parent.width - self.width / 2;
        height: 100%;
        visible-height: parent.height - 20px;
        visible: WindowAdapter.size != WindowSize.sm;
        resized(delta) => {
            let potential-width = Sidebar.side_bar_width + delta;

            if (potential-width < root.collapse-threshold) {
                Sidebar.side_bar_width = root.collapsed-width;
            } else if (potential-width < root.prop-min-width) {
                Sidebar.side_bar_width = root.prop-min-width;
            } else if (potential-width > root.prop-max-width) {
                Sidebar.side_bar_width = root.prop-max-width;
            } else {
                Sidebar.side_bar_width = potential-width;
            }
            Sidebar.side_bar_width_changed(Sidebar.side_bar_width);
        }
    }
}
