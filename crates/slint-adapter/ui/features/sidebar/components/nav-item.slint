import { Theme } from "theme.slint";
import { Icon } from "icons.slint";

export component NavItem inherits Rectangle {
    in-out property <image> icon;
    in-out property <string> icon-key;
    in-out property <string> text: "Processes";
    in-out property <bool> active;
    in-out property <bool> has-icon: true;
    in property <bool> text-visible: true;
    in property <bool> colorize: true;
    in property <bool> indicator-visible: false;
    in property <length> indicator-height: Theme.selection_indicator_height;
    in property <length> indicator-offset-y: (self.height - root.indicator-height) / 2;

    callback clicked;

    height: 40px;
    clip: true;
    background: (active && touch.has-hover) ? Theme.colorNeutralBackgroundAlpha : (active || touch.has-hover) ? Theme.colorNeutralBackgroundAlpha2 : transparent;

    animate background { duration: Theme.durationFaster; }
    border-radius: 6px;

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked()
        }
    }

    Rectangle {
        x: 0;
        y: root.indicator-offset-y;
        width: Theme.selection_indicator_width;
        height: root.indicator-height;
        visible: root.indicator-visible;
        background: Theme.accent_2;
        border-radius: Theme.border_radius_xs;
    }

    HorizontalLayout {
        padding-left: 12px;
        spacing: 12px;

        if (root.has-icon): VerticalLayout {
            alignment: center;
            if (root.icon-key != ""): Icon {
                name: root.icon-key;
                width: 20px;
                height: 20px;
                colorize: active ? Theme.text_primary : Theme.text_secondary;
            }
            if (root.icon-key == ""): Image {
                source: root.icon;
                width: 20px;
                height: 20px;
                image-fit: contain;
                animate colorize { duration: Theme.primary_animation_time; }
            }
        }

        Text {
            text: root.text;
            vertical-alignment: center;
            visible: root.text-visible;
            font-size: Theme.font_size_body;
            color: active ? Theme.text_primary : Theme.text_secondary;
            animate color { duration: Theme.primary_animation_time; }
        }
    }
}
