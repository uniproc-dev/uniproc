import { ListView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { ProcessStatusBar } from "process-status-bar.slint";
import { ProhibitedIcon } from "icons.slint";
import {
    ProcessesFeatureGlobal,
    ProcessEntry,
} from "globals.slint";

import {
    GenericTableRow,
    TableHeader,
    TableColDef,
    TableColWidth,
    TableColMetadata,
    TableUtils,
} from "table/index.slint";



component ProcessItem inherits GenericTableRow {
    in property <ProcessEntry> entry;
    in property <int> idx;

    selected: entry.pid == ProcessesFeatureGlobal.selected-pid;
    is-alternate: Math.mod(idx, 2) != 0;
    column-defs: ProcessesFeatureGlobal.column-defs;
    column-widths: ProcessesFeatureGlobal.column-widths;
    column-metadatas: ProcessesFeatureGlobal.column-metadatas;
    master-text: entry.name;
    master-icon: entry.icon;
    depth: entry.depth;
    has-children: entry.has-children;
    is-expanded: entry.is-expanded;
    is-expandable: true;
    master-color: entry.is-dead ? Theme.text_disabled : white;

    cells: entry.cells;

    clicked => {
        ProcessesFeatureGlobal.select-process(entry.pid, idx);
    }
    toggle-expand => {
        ProcessesFeatureGlobal.toggle-expand-group(entry.name);
    }
}

export component ProcessViewBody inherits Rectangle {
    in property <int> total-rows;
    in property <length> row-height: 32px;

    function emit-viewport() {
        ProcessesFeatureGlobal.rows-viewport-changed(
            TableUtils.viewport-first(list.viewport-y, root.row-height),
            TableUtils.viewport-visible(list.visible-height, root.row-height),
        );
    }

    VerticalLayout {
        TableHeader {
            column-defs: ProcessesFeatureGlobal.column-defs;
            column-widths: ProcessesFeatureGlobal.column-widths;
            column-metadatas: ProcessesFeatureGlobal.column-metadatas;
            current-sort: ProcessesFeatureGlobal.current-sort;
            current-sort-descending: ProcessesFeatureGlobal.current-sort-descending;
            is-grouped: ProcessesFeatureGlobal.is-grouped;
            group-clicked => {
                ProcessesFeatureGlobal.group-clicked();
            }
            resized(id, width) => {
                ProcessesFeatureGlobal.column-resized(id, width);
            }
            sort-by(id) => {
                ProcessesFeatureGlobal.sort-by(id);
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.colorNeutralStrokeAlpha;
        }

        Rectangle {
            vertical-stretch: 1;

            list := ListView {
                changed viewport-y => {
                    root.emit-viewport();
                }
                changed visible-height => {
                    root.emit-viewport();
                }

                for entry[idx] in ProcessesFeatureGlobal.process-rows: ProcessItem {
                    entry: entry;
                    idx: idx;
                }
            }

            if (ProcessesFeatureGlobal.empty-state-visible): Rectangle {
                width: parent.width;
                height: parent.height;
                background: Theme.colorNeutralBackgroundAlpha;

                VerticalLayout {
                    alignment: center;
                    spacing: 10px;

                    Text {
                        text: ProcessesFeatureGlobal.empty-state-title;
                        color: Theme.text_primary;
                        font-size: 16px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: ProcessesFeatureGlobal.empty-state-message;
                        color: Theme.text_secondary;
                        font-size: Theme.font_size_body;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }
        }

        ProcessStatusBar {
            total-count: ProcessesFeatureGlobal.total-processes-count;
        }
    }
}

export component ProcessViewHeader inherits Rectangle {
    property <bool> has-selection: ProcessesFeatureGlobal.selected-pid != -1;
    height: 60px;

    HorizontalLayout {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.has-selection ? ProcessesFeatureGlobal.selected-name : "Processes";
            font-size: 14px;
            font-weight: 600;
            color: Theme.text_primary;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        if (root.has-selection): TouchArea {
            width: 24px;
            clicked => {
                ProcessesFeatureGlobal.terminate();
            }
            ProhibitedIcon {
                colorize: #FF6060;
            }
        }
    }
}
