import { ListView } from "std-widgets.slint";
import { Button } from "button/index.slint";
import { Theme } from "theme.slint";
import { L10n } from "localization.slint";
import { ServicesFeatureGlobal, ServiceEntry } from "globals.slint";
import {
    ServicePropertiesDialogContent,
} from "service-properties-dialog.slint";
import {
    ContentDialogInline,
    ContentDialogMode,
    ContentDialogButtonFooter,
} from "../../components/content-dialog/index.slint";
import {
    GenericTableRow,
    TableHeader,
    TableUtils,
} from "table/index.slint";

component ServiceItem inherits GenericTableRow {
    in property <ServiceEntry> entry;
    in property <int> idx;
    callback properties-requested(int);
    selected: entry.name == ServicesFeatureGlobal.selected-entry.name;
    is-alternate: Math.mod(idx, 2) != 0;
    column-defs: ServicesFeatureGlobal.column-defs;
    column-widths: ServicesFeatureGlobal.column-widths;
    column-metadatas: ServicesFeatureGlobal.column-metadatas;

    master-icon-key: "gears";
    has-master-icon-color: true;
    master-icon-color: white;
    master-text: entry.name;
    depth: 0;
    has-children: false;

    cells: entry.cells;

    context-menu-items: [
        { id: "1", title: "Start", icon-key: "play" },
        { id: "2", title: "Stop", icon-key: "stop" },
        { id: "3", title: "Restart", icon-key: "refresh", has-separator: true },
        { id: "4", title: "Properties", icon-key: "info" }
    ];
    clicked => {
        ServicesFeatureGlobal.select-service(entry.name, idx);
    }
    context-menu-action(action) => {
        ServicesFeatureGlobal.select-service(entry.name, idx);

        if (action == "1") {
            ServicesFeatureGlobal.service-action(entry.name, "Start");
        } else if (action == "2") {
            ServicesFeatureGlobal.service-action(entry.name, "Stop");
        } else if (action == "3") {
            ServicesFeatureGlobal.service-action(entry.name, "Restart");
        } else if (action == "4") {
            root.properties-requested(idx);
        }
    }
}

export component ServiceViewHeader inherits Rectangle {
    in property <ContentDialogMode> properties-dialog-mode: ContentDialogMode.inline;
    property <bool> has-selection: ServicesFeatureGlobal.selected-entry.name != "";
    height: 60px;

    HorizontalLayout {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.has-selection ? ServicesFeatureGlobal.selected-entry.name : "Services";
            font-size: 14px;
            font-weight: 600;
            color: Theme.text_primary;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        HorizontalLayout {
            spacing: 4px;
            alignment: end;
            accessible-role: groupbox;
            accessible-label: "SettingsButtonsGroup";

            Button {
                is-transparent: true;
                icon-key: "play";
                enabled: ServicesFeatureGlobal.start-button-active;
                has-icon-color: true;
                icon-color: Theme.light-green;
                icon-size: 18px;
                text: L10n.services-start;
                clicked => {
                    ServicesFeatureGlobal.service-action(ServicesFeatureGlobal.selected-entry.name, "Start");
                }
            }

            Button {
                is-transparent: true;
                icon-key: "stop";
                enabled: ServicesFeatureGlobal.stop-button-active;
                has-icon-color: true;
                icon-color: Theme.soft-red;
                icon-size: 18px;
                text: L10n.services-stop;
                clicked => {
                    ServicesFeatureGlobal.service-action(ServicesFeatureGlobal.selected-entry.name, "Stop");
                }
            }

            Button {
                is-transparent: true;
                icon-key: "refresh";
                enabled: ServicesFeatureGlobal.restart-button-active;
                text: L10n.services-restart;
                has-icon-color: true;
                icon-color: Theme.light-blue;
                icon-size: 18px;
                clicked => {
                    ServicesFeatureGlobal.service-action(ServicesFeatureGlobal.selected-entry.name, "Restart");
                }
            }
        }
    }
}

export component ServicePropertiesInlineOverlay inherits Rectangle {
    in property <ContentDialogMode> properties-dialog-mode: ContentDialogMode.inline;

    ContentDialogInline {
        is-open <=> ServicesFeatureGlobal.properties-inline-open;
        visible: root.properties-dialog-mode == ContentDialogMode.inline;
        dialog-width: 440px;
        has-footer: true;

        ServicePropertiesDialogContent {
            selected-entry: ServicesFeatureGlobal.selected-entry;

            open-in-window(entry) => {
                ServicesFeatureGlobal.open-properties-window(entry);
            }
            close-requested => {
                ServicesFeatureGlobal.properties-inline-open = false;
            }
            service-action(name, action) => {
                ServicesFeatureGlobal.service-action(name, action);
            }
        }
    }
}

export component ServiceViewBody inherits Rectangle {
    in property <length> row-height: 32px;
    in property <ContentDialogMode> properties-dialog-mode: ContentDialogMode.inline;

    function emit-viewport() {
        ServicesFeatureGlobal.rows-viewport-changed(
            TableUtils.viewport-first(list.viewport-y, root.row-height),
            TableUtils.viewport-visible(list.visible-height, root.row-height),
        );
    }

    VerticalLayout {
        TableHeader {
            column-defs: ServicesFeatureGlobal.column-defs;
            column-widths: ServicesFeatureGlobal.column-widths;
            column-metadatas: ServicesFeatureGlobal.column-metadatas;
            current-sort: ServicesFeatureGlobal.current-sort;
            current-sort-descending: ServicesFeatureGlobal.current-sort-descending;
            is-grouped: false;
            resized(id, width) => {
                ServicesFeatureGlobal.column-resized(id, width);
            }
            sort-by(id) => {
                ServicesFeatureGlobal.sort-by(id);
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.colorNeutralStrokeAlpha;
        }

        list := ListView {
            enabled: root.properties-dialog-mode != ContentDialogMode.inline || !ServicesFeatureGlobal.properties-inline-open;
            changed viewport-y => {
                root.emit-viewport();
            }
            changed visible-height => {
                root.emit-viewport();
            }

            for entry[idx] in ServicesFeatureGlobal.service-rows: ServiceItem {
                entry: entry;
                idx: idx;
                properties-requested(item_idx) => {
                    ServicesFeatureGlobal.select-service(entry.name, item_idx);
                    if (root.properties-dialog-mode == ContentDialogMode.inline) {
                        ServicesFeatureGlobal.properties-inline-open = true;
                    } else {
                        ServicesFeatureGlobal.open-properties-window(entry);
                    }
                }
            }
        }

        Rectangle {
            height: 32px;
            background: Theme.colorNeutralBackgroundAlpha;
            Rectangle {
                width: 100%;
                height: 1px;
                y: 0;
                background: Theme.colorNeutralStrokeAlpha;
            }

            HorizontalLayout {
                padding-left: 8px;
                alignment: start;
                Text {
                    text: "Services: \{ServicesFeatureGlobal.total-services-count}";
                    color: Theme.text_secondary;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }
    }
}
