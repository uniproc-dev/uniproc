import { Icon } from "icons.slint";
import { Theme } from "theme.slint";

export component Button {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    in property <image> icon;
    in property <string> icon-key;
    in property <color> icon-color;
    in property <bool> has-icon-color;
    in property <length> icon-size;
    in property <bool> is-transparent;
    in property <length> prop-padding-left: Theme.spacingHorizontalM;
    in property <length> prop-padding-right: Theme.spacingHorizontalM;
    in property <length> icon-offset-x;
    callback clicked;
    height: 32px;

    accessible-role: button;
    accessible-label: root.text;

    pure callback get-background-color(is-enabled: bool, is-primary: bool, is-transparent: bool, is-pressed: bool, hover: bool) -> color;

    pure callback get-foreground-color(is-enabled: bool, is-primary: bool, is-transparent: bool) -> color;
    pure callback get-contrast-color(background: color) -> color;

    get-contrast-color(background) => {
        let luminance = 0.2126 * background.red + 0.7152 * background.green + 0.0722 * background.blue;
        return luminance > 140 ? Colors.black : Colors.white;
    }

    get-foreground-color(enabled, primary, transparent) => {
        if (!enabled) {
            return Theme.colorNeutralForegroundDisabled;
        }
        if (transparent) {
            return Theme.colorNeutralForeground1;
        }
        if (primary) {
            return root.get-contrast-color(Theme.accent_2);
        }
        return Theme.colorNeutralForeground1;
    }

    get-background-color(enabled, primary, transparent, pressed, hover) => {
        if (!enabled && transparent) {
            return Colors.transparent;
        }
        if (!enabled && !transparent) {
            return Theme.colorNeutralBackgroundDisabled;
        }
        if (transparent && !pressed && !hover) {
            return Colors.transparent;
        }
        if (primary) {
            if (pressed) {
                return Theme.colorBrandBackgroundPressed;
            }
            if (hover) {
                return Theme.colorBrandBackgroundHover;
            }
            return Theme.accent_2;
        }
        if (pressed) {
            return Theme.colorSubtleBackgroundPressed;
        }
        if (hover) {
            return Theme.colorNeutralBackgroundAlpha3;
        }
        return Theme.colorNeutralBackgroundAlpha2;
    }

    pure callback get-icon-color(is-enabled: bool, has-custom-color: bool, custom-color: color, text-color: color) -> color;

    get-icon-color(is-enabled, has-custom, custom, text) => {
        let base-color = has-custom ? custom : text;
        return is-enabled ? base-color : (root.is-transparent ? base-color.with-alpha(0.35) : base-color.with-alpha(0.8));
    }

    forward-focus: focus-scope;

    container := Rectangle {
        border-radius: Theme.borderRadiusMedium;
        border-width: Theme.strokeWidthThin;
        clip: true;

        focus-border := Rectangle {
            z: 10;
            border-radius: Theme.borderRadiusLarge;
            border-width: 2px;
            border-color: focus-scope.has-focus ? Theme.colorNeutralForeground1 : transparent;
        }

        animate background { duration: Theme.durationFaster; }

        background: root.get-background-color(
            root.enabled,
            root.primary,
            root.is-transparent,
            touch.pressed,
            touch.has-hover);
        border-color: root.is-transparent ? transparent : Theme.colorNeutralStrokeAlpha2;

        if (!root.is-transparent): Rectangle {
            y: 0;
            x: 0;
            height: 1px;
            width: 100%;
            background: root.primary ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.05);
            z: 5;
        }

        layout := HorizontalLayout {
            padding-left: root.prop-padding-left;
            padding-right: root.prop-padding-right;
            spacing: Theme.spacingHorizontalS;
            alignment: center;
            if (root.icon-key != "" || root.icon.width > 0): VerticalLayout {
                alignment: center;
                if (root.icon-key != ""): Icon {
                    name: root.icon-key;
                    width: root.icon-size > 0 ? root.icon-size : Theme.icon_size_m;
                    height: root.icon-size > 0 ? root.icon-size : Theme.icon_size_m;
                    x: root.icon-offset-x;
                    colorize: root.get-icon-color(
                        root.enabled,
                        root.has-icon-color,
                        root.icon-color,
                        root.get-foreground-color(root.enabled, root.primary, root.is-transparent));
                }
                if (root.icon-key == ""): Image {
                    source: root.icon;
                    width: root.icon-size > 0 ? root.icon-size : Theme.icon_size_m;
                    height: root.icon-size > 0 ? root.icon-size : Theme.icon_size_m;
                    x: root.icon-offset-x;
                    colorize: root.get-icon-color(
                        root.enabled,
                        root.has-icon-color,
                        root.icon-color,
                        root.get-foreground-color(root.enabled, root.primary, root.is-transparent));
                }
            }
            
            if(root.text != ""): Text {
                text: root.text;
                font-size: Theme.fontSizeBase300;
                vertical-alignment: center;

                color: root.get-foreground-color(root.enabled, root.primary, root.is-transparent);
                animate color { duration: Theme.durationFaster; }
            }
        }

        touch := TouchArea {
            enabled: root.enabled;

            clicked => {
                root.clicked();
            }
            mouse-cursor: self.has-hover ? pointer : default;
        }

        focus-scope := FocusScope {
            focus-on-click: false;
            enabled: root.enabled;
            key-pressed(event) => {
                if (event.text == " " || event.text == "\n") {
                    root.clicked();
                    return accept;
                }
                if (event.text == Key.Escape) {
                    focus-scope.clear-focus();
                    return accept;
                }
                return reject;
            }
        }
    }
}
