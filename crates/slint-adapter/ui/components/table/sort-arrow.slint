import { ArrowUpRegularIcon } from "icons.slint";
export component SortArrow inherits Rectangle {
    in property <bool> descending;

    width: 10px;
    height: 10px;

    ArrowUpRegularIcon {
        colorize: white;
        width: 100%;
        height: 100%;

        transform-rotation: descending ? -90deg : 90deg;
        transform-origin: { x: 2.5px, y: 5px };
    }
}
