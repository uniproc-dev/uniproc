import { ArrowUpRegularIcon, Icon } from "icons.slint";

export component GenericMasterCell inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    in property <string> icon-key;
    in property <color> icon-color;
    in property <bool> has-icon-color;
    in property <int> depth: 0;
    in property <bool> has-children: false;
    in property <bool> is-expanded: false;
    in property <bool> is-expandable: false;
    in property <color> text-color: white;

    callback toggle-expand();

    HorizontalLayout {
        padding-left: 8px + root.depth * 16px;
        spacing: 8px;

        if (root.has-children): Rectangle {
            width: 12px;
            ArrowUpRegularIcon {
                width: 10px;
                height: 10px;
                colorize: root.text-color;
                transform-rotation: root.is-expanded ? 270deg : 180deg;
                animate transform-rotation { duration: 150ms; }
            }

            TouchArea {
                clicked => {
                    root.toggle-expand();
                }
            }
        }
        if (!root.has-children && root.is-expandable): Rectangle {
            width: 12px;
        }

        VerticalLayout {
            alignment: center;

            if (root.icon-key != ""): Icon {
                name: root.icon-key;
                colorize: root.has-icon-color ? root.icon-color : transparent;
                width: 16px;
                height: 16px;
            }
            if (root.icon-key == ""): Image {
                source: root.icon;
                colorize: root.has-icon-color ? root.icon-color : transparent;
                width: 16px;
                height: 16px;
                image-fit: contain;
            }
        }

        Text {
            text: root.text;
            color: root.text-color;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}
